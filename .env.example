# Clara Pipeline — n8n Environment Variables
# Copy this to .env and update as needed.
# docker compose will automatically load .env

# ─────────────────────────────────────────────────────────────────
# Ollama (local LLM — zero cost)
# ─────────────────────────────────────────────────────────────────

# URL to reach Ollama from inside the n8n Docker container.
# On macOS/Windows Docker Desktop: use host.docker.internal
# On Linux with Docker Engine:     use your host's LAN IP or bridge IP
OLLAMA_URL=http://host.docker.internal:11434

# Model to use. Options: mistral (default), llama3, phi3
OLLAMA_MODEL=mistral

# ─────────────────────────────────────────────────────────────────
# n8n
# ─────────────────────────────────────────────────────────────────

# Webhook base URL — must be reachable from your browser
WEBHOOK_URL=http://localhost:5678

# Enable basic auth for shared environments (optional)
N8N_BASIC_AUTH_ACTIVE=false
# N8N_BASIC_AUTH_USER=admin
# N8N_BASIC_AUTH_PASSWORD=changeme

# Timezone for n8n scheduler (not used by clara, but good practice)
GENERIC_TIMEZONE=America/New_York
